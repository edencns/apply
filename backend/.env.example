# 데이터베이스
DATABASE_URL=postgresql://apply_user:apply_pass@localhost:5432/apply_db

# Redis
REDIS_URL=redis://localhost:6379/0

# 보안 (반드시 변경)
SECRET_KEY=your-super-secret-key-change-this

# AI (서류 분석, 계약서 오류 검수)
ANTHROPIC_API_KEY=sk-ant-...

# 파일 업로드
UPLOAD_DIR=/tmp/apply_uploads
MAX_UPLOAD_SIZE_MB=50

# 알림톡
KAKAO_API_KEY=

# 이메일
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
